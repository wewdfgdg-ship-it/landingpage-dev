generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// 인증 & 조직
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id         String   @id @default(cuid())
  name       String
  plan       PlanType @default(FREE)
  quotaUsed  Int      @default(0)
  quotaLimit Int      @default(3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships        Membership[]
  projects           Project[]
  subscriptions      Subscription[]
  payments           Payment[]
  couponRedemptions  CouponRedemption[]
  creditBalance      CreditBalance?
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  orgId     String
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

enum PlanType {
  FREE
  PRO
  BUSINESS
}

model Plan {
  id          String   @id // FREE, PRO, BUSINESS
  name        String   // 표시 이름
  description String   @default("")
  price       Int      @default(0) // 월 KRW
  yearlyPrice Int      @default(0) // 연간 KRW (월 환산)
  quotaLimit  Int      @default(3) // 프로젝트 수 제한
  features    Json     @default("[]") // string[]
  generateLimit Int    @default(5) // 월 생성 횟수 (-1 = 무제한)
  deployLimit   Int    @default(1)
  exportEnabled       Boolean @default(true)
  customDomainEnabled Boolean @default(false)
  analyticsEnabled    Boolean @default(true)
  abTestEnabled       Boolean @default(false)
  sortOrder   Int      @default(0) // 정렬 순서
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

// ============================================================
// 프로젝트 & 생성
// ============================================================

model Project {
  id        String        @id @default(cuid())
  orgId     String
  name      String
  slug      String?       @unique
  status    ProjectStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  // 입력 데이터
  inputData Json? // Step 1~3 구조화 입력
  inputScore Int? // 입력 품질 점수 (0~100)

  // 엔진 출력 (각 엔진 결과 JSON)
  productBrief      Json? // ① Product Intelligence
  urgencyBrief      Json? // ② Why Now
  strategyBlueprint Json? // ③ Conversion Strategy
  objectionMap      Json? // ④ Objection Killer
  copyBlocks        Json? // ⑤ Psychological Copy
  trustConfig       Json? // ⑥ Trust Architecture
  attentionConfig   Json? // ⑦ Attention Architecture
  layoutConfig      Json? // ⑧ Layout Intelligence
  styleConfig       Json? // ⑨ Visual Style
  generatedHtml     String? @db.Text // ⑩ Code Engine 최종 HTML
  generatedPage     Json? // ⑩ Code Engine 메타+섹션 데이터

  // 배포
  isDeployed    Boolean @default(false)
  deployedAt    DateTime?
  customDomain  String?  @unique
  previewToken  String?  @unique  // 배포 전 공유 미리보기 토큰

  org            Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sections       Section[]
  pageVersions   PageVersion[]
  abTests        ABTest[]
  dailyAnalytics DailyAnalytics[]
  diagnosisLogs  DiagnosisLog[]
  generatedImages GeneratedImage[]

  @@index([orgId])
  @@index([slug])
}

enum ProjectStatus {
  DRAFT
  GENERATING
  GENERATED
  EDITING
  DEPLOYED
  ARCHIVED
}

model Section {
  id        String   @id @default(cuid())
  projectId String
  order     Int
  role      SectionRole
  type      String // hero_visual, pain_point, benefit_highlight 등
  zone      Int? // 1~4 (Attention Architecture Zone)

  // 카피
  headline    String? @db.Text
  subheadline String? @db.Text
  body        String? @db.Text
  bulletPoints Json? // string[]
  ctaText     String?
  microCopy   String?

  // 레이아웃 & 스타일
  layoutPattern String? // 42패턴 중 선택된 패턴명
  customStyle   Json? // 섹션별 스타일 오버라이드

  // 이미지
  imageUrl       String? // R2 CDN URL
  imageDirection String? @db.Text // 이미지 생성용 디렉션

  // 신뢰 & 저항 파괴
  trustLevel     Int? // 1~6
  objectionType  String? // price, trust, need, complexity
  objectionStrategies Json? // string[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sectionAnalytics SectionAnalytics[]

  @@index([projectId])
  @@index([projectId, order])
}

enum SectionRole {
  HOOK
  PAIN
  SOLUTION
  PROOF
  OBJECTION
  URGENCY
  CTA
  FEATURE
  FAQ
  FOOTER
}

model PageVersion {
  id        String   @id @default(cuid())
  projectId String
  version   Int
  label     String? // "원본", "A/B 변형 1" 등

  htmlContent   String? @db.Text // 빌드된 HTML
  reactContent  String? @db.Text // React 코드
  sectionSnapshot Json? // 섹션 스냅샷

  // 성과
  trafficWeight Float @default(100) // A/B 트래픽 비율
  totalVisits   Int   @default(0)
  totalConversions Int @default(0)
  conversionRate Float @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  abTestsAsControl ABTest[] @relation("ControlVersion")
  abTestsAsVariant ABTest[] @relation("VariantVersion")

  @@index([projectId])
  @@unique([projectId, version])
}

// ============================================================
// A/B 테스트 & 학습
// ============================================================

model ABTest {
  id        String       @id @default(cuid())
  projectId String
  status    ABTestStatus @default(RUNNING)

  controlVersionId String
  variantVersionId String

  // 설정
  optimizationLevel Int // 1=미세, 2=구조, 3=전체
  targetMetric      String @default("conversion_rate")
  minSampleSize     Int    @default(100)

  // 결과
  controlConversionRate Float?
  variantConversionRate Float?
  winner                String? // "control" | "variant"
  confidence            Float? // 통계적 유의도

  startedAt   DateTime  @default(now())
  concludedAt DateTime?

  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  controlVersion PageVersion @relation("ControlVersion", fields: [controlVersionId], references: [id])
  variantVersion PageVersion @relation("VariantVersion", fields: [variantVersionId], references: [id])

  @@index([projectId])
}

enum ABTestStatus {
  RUNNING
  CONCLUDED
  CANCELLED
}

model WinningPattern {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // 분류
  industry      String // SaaS, 이커머스, 교육 등
  goal          String // 구매, 가입, 문의 등
  patternType   String // layout, copy_frame, section_order 등

  // 내용
  patternData   Json // 승리한 패턴 상세
  winRate       Float // 승률
  sampleSize    Int // 테스트 참여 수
  improvement   Float // 기존 대비 개선율

  @@index([industry, goal])
}

// ============================================================
// 분석 & 진단
// ============================================================

model DailyAnalytics {
  id        String   @id @default(cuid())
  projectId String
  date      DateTime @db.Date

  // 트래픽
  totalVisits     Int @default(0)
  uniqueVisitors  Int @default(0)

  // 전환
  totalConversions Int @default(0)
  conversionRate   Float @default(0)

  // 참여
  avgScrollDepth   Float @default(0) // 평균 스크롤 깊이 (%)
  avgTimeOnPage    Float @default(0) // 평균 체류시간 (초)
  bounceRate       Float @default(0)

  // 유입원
  sourceBreakdown Json? // { "direct": 30, "google": 50, ... }

  // 디바이스
  deviceBreakdown Json? // { "mobile": 60, "desktop": 35, "tablet": 5 }

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([projectId])
}

model SectionAnalytics {
  id        String   @id @default(cuid())
  sectionId String
  date      DateTime @db.Date

  impressions   Int   @default(0) // 노출 수
  avgDwellTime  Float @default(0) // 평균 체류시간 (초)
  exitRate      Float @default(0) // 이탈률 (%)
  ctaClicks     Int   @default(0) // CTA 클릭 수

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, date])
  @@index([sectionId])
}

model DiagnosisLog {
  id        String   @id @default(cuid())
  projectId String
  createdAt DateTime @default(now())

  // 진단
  diagnosisType String // hero_weak, section_dropout, cta_ignored 등
  severity      String // low, medium, high, critical
  details       Json // 진단 상세

  // 처방
  prescriptionLevel Int // 1, 2, 3
  prescription      Json // 처방 내용

  // 결과
  applied   Boolean @default(false)
  appliedAt DateTime?
  result    Json? // 적용 후 결과

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// 이미지
// ============================================================

model GeneratedImage {
  id        String   @id @default(cuid())
  projectId String
  createdAt DateTime @default(now())

  // R2 저장
  storageKey String // R2 key
  cdnUrl     String // CDN URL
  mimeType   String @default("image/jpeg")
  fileSize   Int? // bytes

  // 생성 정보
  prompt       String @db.Text
  sectionType  String? // hero_visual, benefit 등
  model        String @default("gemini-flash")
  cost         Float? // USD

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ============================================================
// 결제
// ============================================================

model Subscription {
  id        String             @id @default(cuid())
  orgId     String
  status    SubscriptionStatus @default(ACTIVE)
  plan      PlanType

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  cancelReason       String?

  // Trial
  trialEnd   DateTime?
  isTrial    Boolean @default(false)

  // 쿠폰
  couponId String?

  externalId String? @unique // 결제사 구독 ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  CANCELLED
}

model Payment {
  id        String        @id @default(cuid())
  orgId     String
  amount    Int // 원 단위
  currency  String        @default("KRW")
  status    PaymentStatus @default(PENDING)
  provider  String        @default("payapp")

  externalId String? @unique // 결제사 거래 ID
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================================
// 쿠폰 & 프로모션
// ============================================================

model Coupon {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String // 관리자용 이름
  description String?

  // 할인 설정
  discountType  DiscountType @default(PERCENT)
  discountValue Int // PERCENT: 10=10%, FIXED: 5000=5000원

  // 적용 조건
  applicablePlans PlanType[] // 빈 배열 = 전체 적용
  minAmount       Int        @default(0) // 최소 결제 금액
  maxUses         Int        @default(0) // 0=무제한
  maxUsesPerOrg   Int        @default(1) // 조직당 사용 횟수

  // 기간
  startsAt  DateTime @default(now())
  expiresAt DateTime?

  isActive  Boolean  @default(true)
  usedCount Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions CouponRedemption[]
}

enum DiscountType {
  PERCENT
  FIXED
}

model CouponRedemption {
  id       String   @id @default(cuid())
  couponId String
  orgId    String
  amount   Int // 실제 할인 금액
  usedAt   DateTime @default(now())

  coupon Coupon       @relation(fields: [couponId], references: [id])
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([orgId])
}

// ============================================================
// 크레딧 시스템
// ============================================================

model CreditBalance {
  id    String @id @default(cuid())
  orgId String @unique

  balance   Int @default(0) // 잔여 크레딧
  totalUsed Int @default(0) // 누적 사용

  updatedAt DateTime @updatedAt

  org          Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]
}

model CreditTransaction {
  id              String           @id @default(cuid())
  creditBalanceId String
  type            CreditTxType
  amount          Int // 양수=충전, 음수=차감
  reason          String // "trial_bonus", "generation", "purchase" 등
  referenceId     String? // 관련 프로젝트/결제 ID

  createdAt DateTime @default(now())

  creditBalance CreditBalance @relation(fields: [creditBalanceId], references: [id], onDelete: Cascade)

  @@index([creditBalanceId])
}

enum CreditTxType {
  TRIAL_BONUS // 트라이얼 시작 보너스
  PURCHASE    // 크레딧 구매
  GENERATION  // 랜딩페이지 생성 차감
  REGENERATION // 재생성 차감
  IMAGE       // 이미지 생성 차감
  REFUND      // 환불 복구
  ADMIN       // 관리자 수동 조정
  PROMO       // 프로모션 지급
}

// ============================================================
// 섹션 레퍼런스 (26섹션 × 18업종 × 4트리트먼트)
// ============================================================

model SectionReference {
  id        String          @id @default(cuid())

  sectionType String        // HEADER_BANNER, KEY_FEATURES, ...
  industry    String        // beauty, food, fashion, ...
  treatment   String        // photo, text, graphic, animation
  status      ReferenceStatus @default(PENDING)

  imageUrl    String        // 스크린샷 URL
  sourceUrl   String?       // 원본 페이지 URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectionType])
  @@index([industry])
  @@index([status])
  @@index([sectionType, industry])
}

enum ReferenceStatus {
  PENDING   // 대기중
  APPROVED  // 승인 (O)
  REJECTED  // 거절 (X)
}

// ============================================================
// 크롤링 작업 관리
// ============================================================

model CrawlJob {
  id          String      @id @default(cuid())

  sectionType String        // 요청 섹션 타입
  industry    String        // 요청 업종
  treatment   String        // 요청 트리트먼트 (photo, text 등)
  count       Int           // 요청 수량
  status      CrawlStatus   @default(QUEUED)

  sourceSites String[]      // 검색 대상 사이트 (옵션)
  keywords    String[]      // 검색 키워드 목록
  memo        String?       // 관리자 메모

  collected   Int           @default(0)  // 수집된 수량
  errorMsg    String?       // 에러 메시지

  createdAt   DateTime      @default(now())
  startedAt   DateTime?     // 크롤링 시작 시각
  completedAt DateTime?     // 크롤링 완료 시각

  @@index([status])
  @@index([sectionType, industry])
}

enum CrawlStatus {
  QUEUED      // 대기
  RUNNING     // 진행중
  COMPLETED   // 완료
  FAILED      // 실패
  CANCELLED   // 취소
}

// ============================================================
// 업종별 키워드 프리셋
// ============================================================

model IndustryKeywordPreset {
  id        String   @id @default(cuid())
  industry  String   @unique  // beauty, food, fashion, ...
  keywords  String[]          // 검색 키워드 목록
  updatedAt DateTime @updatedAt
}
